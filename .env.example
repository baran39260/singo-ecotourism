# ──────────────────────────────────────────────────────────────────────────────
# سینگو — نمونه فایل متغیرهای محیطی
# این فایل را به `.env.local` کپی کنید و مقادیر واقعی را پر کنید.
# هرگز `.env.local` را commit نکنید (در .gitignore است).
# ──────────────────────────────────────────────────────────────────────────────

# ─── محیط ────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug                          # debug | info | warn | error

# ─── دیتابیس (پروپوزال ۱، تسک ۵) ─────────────────────────────────────────────
# PostgreSQL — برای dev محلی می‌توانید docker-compose بالا بیاورید
DATABASE_URL=postgresql://singo:singo@localhost:5432/singo_dev

# ─── احراز هویت Auth.js v5 (پروپوزال ۱، تسک ۷) ───────────────────────────────
# تولید مقدار: `openssl rand -base64 32`
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Sentry (پروپوزال ۱، تسک ۱۰) ─────────────────────────────────────────────
# در dev اختیاری است؛ خالی بگذارید تا silent باشد.
# در prod اگر خالی باشد، startup یک warning می‌زند ولی crash نمی‌کند.
SENTRY_DSN=

# ─── Rate Limiting (پروپوزال ۱، تسک ۸) ───────────────────────────────────────
# در dev بدون Redis، fallback in-memory استفاده می‌شود.
# در prod، RATE_LIMIT_REDIS_URL الزامی است وگرنه startup شکست می‌خورد.
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Placeholder برای پروپوزال‌های بعدی — هنوز فعال نیستند
# ──────────────────────────────────────────────────────────────────────────────

# ─── کاوه‌نگار (پروپوزال ۲) ─────────────────────────────────────────────────
# اگر تنظیم نشد، در dev از MockSmsClient استفاده می‌شود
# KAVENEGAR_API_KEY=
# KAVENEGAR_OTP_TEMPLATE=singo-otp

# ─── آروان S3 (پروپوزال ۲) ──────────────────────────────────────────────────
# اگر تنظیم نشد، فایل‌ها در public/uploads/ ذخیره می‌شوند (MockStorageClient)
# ARVAN_S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
# ARVAN_S3_REGION=ir-thr-at1
# ARVAN_S3_BUCKET=singo-demo
# ARVAN_S3_ACCESS_KEY=
# ARVAN_S3_SECRET_KEY=
# ARVAN_S3_PUBLIC_URL=https://singo-demo.s3.ir-thr-at1.arvanstorage.ir

# ─── زرین‌پال (پروپوزال ۵) ───────────────────────────────────────────────────
# ZARINPAL_MERCHANT_ID=
# ZARINPAL_SANDBOX=true

# ─── واتساپ Business API (پروپوزال ۶) ───────────────────────────────────────
# WHATSAPP_API_PROVIDER=ultramsg               # ultramsg | meta
# WHATSAPP_API_KEY=
# WHATSAPP_BUSINESS_NUMBER=

# ─── سامانه‌های قانونی ایران (پروپوزال ۴) ────────────────────────────────────
# سامانه مسافر پلیس اماکن
# AMAKEN_API_URL=
# AMAKEN_USERNAME=
# AMAKEN_PASSWORD=

# سامانه مؤدیان مالیاتی
# MODAYAN_CERT_PATH=
# MODAYAN_PRIVATE_KEY_PATH=
# MODAYAN_TAXPAYER_ID=
